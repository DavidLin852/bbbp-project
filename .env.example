# ============================================================
# BBB Prediction Platform - 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据需要修改
# cp .env.example .env
# ============================================================

# ====================
# Streamlit 配置
# ====================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ====================
# Python 配置
# ====================
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ====================
# 应用配置
# ====================
# 默认随机种子
DEFAULT_SEED=0
# 默认阈值
DEFAULT_THRESHOLD=0.5
# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE=200

# ====================
# 路径配置 (可选)
# ====================
# DATA_ROOT=/app/data
# ARTIFACTS_ROOT=/app/artifacts
# OUTPUTS_ROOT=/app/outputs

# ====================
# GPU 配置 (可选)
# ====================
# CUDA_VISIBLE_DEVICES=0
